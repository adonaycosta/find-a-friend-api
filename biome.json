{
	"$schema": "https://biomejs.dev/schemas/2.3.2/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "space",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedFunctionParameters": "off",
				"noUnusedVariables": "off"
			},
			"suspicious": {
				"noGlobalIsNan": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "off"
			},
			"complexity": {
				"useLiteralKeys": "off"
			}
		}
	}
}